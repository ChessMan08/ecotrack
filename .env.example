# ── Firebase Configuration ────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get from: Google AI Studio → https://aistudio.google.com/app/apikey
# IMPORTANT: This is server-side only (no NEXT_PUBLIC_ prefix) — never exposed to the browser
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Demo Mode ───────────────────────────────────────────────────────
# Set to "true" to enable a demo/guest mode that skips Firebase auth
NEXT_PUBLIC_DEMO_MODE=false

# ── App URL (for production) ──────────────────────────────────────────────────
# Primary deployment is via Vercel
NEXT_PUBLIC_APP_URL=https://ecotrack-nu-flame.vercel.app
